# Backend base URL the frontend calls.
#
# - Production: set in .env.production (committed) -> https://portfolio.sudodeveloper.com
# - Local dev: leave unset to use the http://localhost:8081 fallback in src/lib/api.js,
#   or copy this to .env.local (git-ignored) to override.
VITE_API_BASE_URL=http://localhost:8081
